{
  "regions": ["sin1"],
  "functions": {
    "api/proxy.js": { "maxDuration": 30 },
    "api/cdn-proxy.js": { "maxDuration": 30 }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/proxy?__path=/:path*"
    },
    {
      "source": "/cdn-proxy",
      "destination": "/api/cdn-proxy"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
